    -- Coba load dari file
    savedKey = LoadSavedKey()
end

if savedKey then
    -- Langsung verifikasi tanpa tampilkan UI
    ShowNotification("🔄 Memuat key tersimpan...", false)
    task.wait(0.5)
    VerifyKey(savedKey)
else
    -- Tampilkan UI input key
    ShowKeyInput(function(inputtedKey)
        VerifyKey(inputtedKey)
    end)
end
