if typeof(script_key) ~= "string" or script_key == "" then
    KickPlayer("missing_key")
    return
end

local KEY = tostring(script_key)

local response = Request({
    Url = API_URL
        .. "?key=" .. HttpService:UrlEncode(KEY)
        .. "&device=" .. HttpService:UrlEncode(DEVICE_ID),
    Method = "GET",
    Headers = {
        ["Content-Type"] = "application/json"
    }
})

if not response or not response.Body then
    ShowNotification("❌ Gagal terhubung ke server", true)
    task.wait(1)
    KickPlayer("server_fail")
    return
end

local data
local success = pcall(function()
    data = HttpService:JSONDecode(response.Body)
end)

if not success or typeof(data) ~= "table" then
    ShowNotification("❌ Response server tidak valid", true)
    task.wait(1)
    KickPlayer("invalid_resp")
    return
end

if not data.allowed then
    local reason = data.reason or "unknown"

    local notifMessages = {
        missing_key     = "❌ Key tidak terdeteksi",
        invalid_key     = "❌ Key tidak valid",
        device_mismatch = "❌ Key sudah dipakai di device lain",
        expired         = "⏳ Key sudah expired",
    }

    ShowNotification(notifMessages[reason] or "❌ Akses ditolak", true)
    task.wait(1)
    KickPlayer(reason)
    return
end

if data.type == "lifetime" then
    ShowNotification("💎 Lifetime Premium Activated", false)
elseif data.type == "30d" then
    ShowNotification("⏳ Premium Active  |  Expired: " .. tostring(data.expires), false)
else
    ShowNotification("✅ Premium Access Granted", false)
end

task.wait(1)

pcall(function()
    loadstring(game:HttpGet(
        "https://nexahub.pythonanywhere.com/script.lua"
    ))()
end)
