    task.delay(5, function()
        if gui and gui.Parent then
            TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                Position = UDim2.new(1, 50, 0.1, 0)
            }):Play()
            task.wait(0.3)
            gui:Destroy()
