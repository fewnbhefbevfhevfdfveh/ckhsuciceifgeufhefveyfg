local function ShowKickScreen(title, message)
    local playerGui = player:WaitForChild("PlayerGui")
    for _, g in pairs(playerGui:GetChildren()) do
        if g.Name == "NexaKickScreen" then g:Destroy() end
    end

    local gui = Instance.new("ScreenGui")
    gui.Name = "NexaKickScreen"
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.Parent = playerGui

    local card = CreateCard(gui)
    AddCardText(card, title, message)

    TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundTransparency = 0,
    }):Play()

    task.wait(3)
end

local function KickPlayer(reason)
    local entry = KICK_MESSAGES[reason] or { "🔐 Nexa Hub", "Akses kamu ditolak.\nHubungi admin untuk informasi lebih lanjut." }
    ShowKickScreen(entry[1], entry[2])
    player:Kick(entry[1] .. " — " .. entry[2]:gsub("\n", " "))
end

