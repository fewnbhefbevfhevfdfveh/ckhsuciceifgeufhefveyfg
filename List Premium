local function HideLoadingScreen()
    if _loadingGui then
        local card = _loadingGui:FindFirstChildWhichIsA("Frame", true)
        if card then
            TweenService:Create(card, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
                BackgroundTransparency = 1,
                Position = UDim2.new(0.5, 0, 0.6, 0),
            }):Play()
        end
        task.delay(0.25, function()
            if _loadingGui then
                _loadingGui:Destroy()
                _loadingGui = nil
            end
        end)
    end
end

local function ShowRateLimitCountdown(retryAfter)
    local secs = tonumber(retryAfter) or 10
    for i = secs, 1, -1 do
        ShowNotification("⏱️ Rate limited — tunggu " .. i .. " detik...", true)
        task.wait(1)
    end
end

if not Request then
    KickPlayer("no_executor")
    return
end

if typeof(script_key) ~= "string" or script_key:match("^%s*$") then
    KickPlayer("missing_key")
    return
end

local KEY = tostring(script_key):match("^%s*(.-)%s*$")

local loadingGui, statusLabel, subLabel = ShowLoadingScreen()

local response = nil
local data     = nil
local lastReason = "server_fail"

for attempt = 1, MAX_RETRIES do
    if statusLabel then
        statusLabel.Text = "Menghubungi server... (" .. attempt .. "/" .. MAX_RETRIES .. ")"
    end

    local reqSuccess = pcall(function()
        response = Request({
            Url = API_URL
                .. "?key="    .. HttpService:UrlEncode(KEY)
                .. "&device=" .. HttpService:UrlEncode(DEVICE_ID),
            Method  = "GET",
            Headers = { ["Content-Type"] = "application/json" },
            Timeout = TIMEOUT,
        })
    end)

    if not reqSuccess or not response or not response.Body then
        if attempt < MAX_RETRIES then
            if statusLabel then
                statusLabel.Text = "Koneksi gagal, mencoba ulang..."
            end
            task.wait(RETRY_DELAY)
        end
    else
        local parseOk = pcall(function()
            data = HttpService:JSONDecode(response.Body)
        end)

        if not parseOk or typeof(data) ~= "table" then
            lastReason = "invalid_resp"
            if attempt < MAX_RETRIES then
                task.wait(RETRY_DELAY)
            end
        elseif not data.allowed and data.reason == "rate_limited" then
            lastReason = "rate_limited"
            local retryAfter = data.retry_after or 10
            if statusLabel then
                statusLabel.Text = "Rate limited — tunggu " .. retryAfter .. " detik"
            end
            HideLoadingScreen()
            ShowRateLimitCountdown(retryAfter)
            if attempt < MAX_RETRIES then
                loadingGui, statusLabel, subLabel = ShowLoadingScreen()
            end
        else
            lastReason = tostring(data.reason or "invalid_key")
            break
        end
    end
end

if not data or typeof(data) ~= "table" then
    HideLoadingScreen()
    ShowNotification(NOTIF_MESSAGES[lastReason] or NOTIF_MESSAGES.server_fail, true)
    task.wait(1)
    KickPlayer(lastReason)
    return
end

if not data.allowed then
    local reason = tostring(data.reason or "invalid_key")
    HideLoadingScreen()
    ShowNotification(NOTIF_MESSAGES[reason] or "❌ Akses ditolak", true)
    task.wait(1)
    KickPlayer(reason)
    return
end

local SCRIPT_URL = data.script_url

if not SCRIPT_URL or type(SCRIPT_URL) ~= "string" or SCRIPT_URL == "" then
    HideLoadingScreen()
    ShowNotification(NOTIF_MESSAGES.no_script_url, true)
    task.wait(1)
    KickPlayer("no_script_url")
    return
end

local escapedDomain = SCRIPT_DOMAIN:gsub("%.", "%%.")
if not SCRIPT_URL:match("^https://" .. escapedDomain .. "/") then
    HideLoadingScreen()
    ShowNotification("⚠️ URL script tidak valid", true)
    task.wait(1)
    KickPlayer("invalid_resp")
    return
end

local successMsg = ""
if data.type == "lifetime" then
    successMsg = "💎 Lifetime Premium Activated!"
    if statusLabel then statusLabel.Text = successMsg end
    if subLabel    then subLabel.Text    = "Memuat script..." end
elseif data.type == "30d" then
    local daysLeft = data.days_remaining or 0
    successMsg = "⏳ Active  |  " .. daysLeft .. " hari tersisa  |  Exp: " .. tostring(data.expires)
    if statusLabel then statusLabel.Text = "Premium Active!" end
    if subLabel    then subLabel.Text    = daysLeft .. " hari tersisa · Exp " .. tostring(data.expires) end
else
    successMsg = "✅ Premium Access Granted"
    if statusLabel then statusLabel.Text = successMsg end
end

task.wait(0.8)
HideLoadingScreen()
ShowNotification(successMsg, false)

local loadOk, loadErr = pcall(function()
    loadstring(game:HttpGet(SCRIPT_URL))()
end)

if not loadOk then
    ShowNotification("⚠️ Gagal memuat script utama: " .. tostring(loadErr), true)
end
