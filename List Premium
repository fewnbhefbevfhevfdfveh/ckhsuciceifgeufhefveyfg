local function KickPlayer(reason)
    local entry = KICK_MESSAGES[reason] or { "🔐 Nexa Hub", "Akses kamu ditolak.\nHubungi admin untuk informasi lebih lanjut." }
    ShowKickScreen(entry[1], entry[2])
    player:Kick(entry[1] .. " — " .. entry[2]:gsub("\n", " "))
end

