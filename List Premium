-- KEY STORAGE (simpan & baca dari file executor)
-- ==============================
local function SaveKey(key)
    if writefile then
        pcall(writefile, KEY_FILE, key)
    end
end

local function LoadSavedKey()
    if readfile and isfile and isfile(KEY_FILE) then
        local ok, content = pcall(readfile, KEY_FILE)
        if ok and content and content:match("^%S+$") then
            return content:match("^%s*(.-)%s*$")
        end
    end
    return nil
end

local function DeleteSavedKey()
    if delfile and isfile and isfile(KEY_FILE) then
        pcall(delfile, KEY_FILE)
    end
end

