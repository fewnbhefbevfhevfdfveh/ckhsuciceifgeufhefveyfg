    (syn and syn.request)                                       or
    (typeof(http_request)  == "function" and http_request)      or
    (typeof(request)       == "function" and request)           or
    (fluxus and fluxus.request)                                 or
    (krnl   and krnl.request)                                   or
    safeGet(function() return KRNL_Execute and KRNL_Execute.request end) or
    (electron and electron.request)                             or
