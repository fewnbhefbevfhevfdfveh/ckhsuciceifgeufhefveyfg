-- ==============================
-- VERIFIKASI KEY KE SERVER
-- ==============================
local function VerifyKey(KEY)
    ShowNotification("🔄 Memverifikasi key...", false)

    local response
    local reqSuccess = pcall(function()
        response = Request({
            Url = API_URL
                .. "?key="    .. HttpService:UrlEncode(KEY)
                .. "&device=" .. HttpService:UrlEncode(DEVICE_ID),
            Method  = "GET",
            Headers = { ["Content-Type"] = "application/json" },
            Timeout = TIMEOUT,
        })
    end)

    if not reqSuccess or not response or not response.Body then
        ShowNotification(NOTIF_MESSAGES.server_fail, true)
        task.wait(1)
        KickPlayer("server_fail")
        return
    end

    local data
    local parseOk = pcall(function()
        data = HttpService:JSONDecode(response.Body)
    end)

    if not parseOk or typeof(data) ~= "table" then
        ShowNotification(NOTIF_MESSAGES.invalid_resp, true)
        task.wait(1)
        KickPlayer("invalid_resp")
        return
    end

    if not data.allowed then
        local reason = tostring(data.reason or "invalid_key")

        -- Kalau key invalid/expired, hapus file supaya user input ulang
        if reason == "invalid_key" or reason == "expired" or reason == "device_mismatch" then
            DeleteSavedKey()
        end

        ShowNotification(NOTIF_MESSAGES[reason] or "❌ Akses ditolak", true)
        task.wait(1)
        KickPlayer(reason)
        return
    end

    -- Key valid — simpan ke file
    SaveKey(KEY)

    -- Validasi script_url
    local SCRIPT_URL = data.script_url
    if not SCRIPT_URL or type(SCRIPT_URL) ~= "string" or SCRIPT_URL == "" then
        ShowNotification(NOTIF_MESSAGES.no_script_url, true)
        task.wait(1)
        KickPlayer("no_script_url")
        return
    end

    if not SCRIPT_URL:match("^https://nexahub%.pythonanywhere%.com/") then
        ShowNotification("⚠️ URL script tidak valid", true)
        task.wait(1)
        KickPlayer("invalid_resp")
        return
    end

    -- Tampilkan notif sukses
    if data.type == "lifetime" then
        ShowNotification("💎 Lifetime Premium Activated!", false)
    elseif data.type == "30d" then
        local daysLeft = data.days_remaining or 0
        ShowNotification("⏳ Premium Active  |  " .. daysLeft .. " hari tersisa  |  Exp: " .. tostring(data.expires), false)
    else
        ShowNotification("✅ Premium Access Granted", false)
    end

    task.wait(0.8)

    local loadOk, loadErr = pcall(function()
        loadstring(game:HttpGet(SCRIPT_URL))()
    end)

    if not loadOk then
        ShowNotification("⚠️ Gagal memuat script utama: " .. tostring(loadErr), true)
    end
end

